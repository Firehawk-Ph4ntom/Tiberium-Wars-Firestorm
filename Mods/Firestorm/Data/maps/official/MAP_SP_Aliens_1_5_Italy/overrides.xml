<?xml version="1.0" encoding="UTF-8"?>
<AssetDeclaration xmlns="uri:ea.com:eala:asset" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xai="uri:ea.com:eala:asset:instance">
	<Tags/>
	<Includes>
		<!-- For Alien Wormhole -->
		<Include source="DATA:Firestorm\Data\Data\Alien\Props\AlienWormHole.xml" type="instance"/>
		<!-- For Alien Tower -->
		<Include source="DATA:Firestorm\Data\Data\Alien\Structures_Singleplayer\ABTower.xml" type="instance"/>
		<!-- For Alien Phase Generator -->
		<Include source="DATA:Firestorm\Data\Data\Alien\Structures_Singleplayer\AlienPhaseGenerator.xml" type="instance"/>
		<!-- For Alien Signal Transmitter -->
		<Include source="DATA:FireStorm\Data\Data\Alien\Structures\Buildings\AlienSignalTransmitter.xml" type="instance"/>
		<!-- For Alien Mothership -->
		<Include source="DATA:FireStorm\Data\Data\Alien\Units\Aircraft\AlienMothership.xml" type="instance"/>

		<!-- For Mod's Global Sound Data -->
		<Include source="DATA:Firestorm\Data\Data\Misc\Sounds\SoundEffects.xml" type="instance"/>
		<Include source="DATA:Firestorm\Data\Data\Misc\Sounds\Voice.xml" type="instance"/>
	</Includes>

	<!-- Alien Tower -->
	<GameObject
		id="ABTower"
		inheritFrom="ABTower"/>

	<!-- Alien Phase Generator -->
	<GameObject
		id="Alien_PhaseGenerator"
		inheritFrom="Alien_PhaseGenerator"/>

	<!-- SP Doesn't reload | Removed cost -->
	<SpecialPowerTemplate
		id="SpecialPower_SummonMothership"
		Flags="IS_PLAYER_POWER WATER_OK SHARED_SYNC"
		ReloadTime="999999s"
		TargetType="NONE"
		Money="0"
		InitiateAtLocationSound="ALI_MotherShip_SoundCreate"
		EvaEventToPlayOnInitiateOwner="MothershipDeployed"
		EvaEventToPlayOnInitiateEnemy="WarningMothershipDeployed">
		<GameDependency>
			<ForbiddenUpgrade>Upgrade_MotherShipBuilt</ForbiddenUpgrade>
		</GameDependency>
	</SpecialPowerTemplate>

	<!-- Mothership spawns at player Spawn point (InitialCameraPosition) -->
	<GameObject
		id="AlienSignalTransmitter"
		inheritFrom="AlienSignalTransmitter">
		<Behaviors>
			<OCLSpecialPower
				id="ModuleTag_SummonMothership"
				xai:joinAction="Replace"
				SpecialPowerTemplate="SpecialPower_SummonMothership"
				OCL="OCL_SummonMothership"
				CreateLocation="CREATE_CLOSEST_TO_SPAWN_POINT"/>
		</Behaviors>
	</GameObject>

	<!-- Increased Health from 28000 -->
	<GameObject
		id="AlienMothership"
		inheritFrom="AlienMothership">
		<Body>
			<ShieldBody
				id="ModuleTag_Body"
				xai:joinAction="Append"
				MaxHealth="45000"/>
		</Body>
	</GameObject>

	<!-- Increased LifetimeUpdate to last the whole mission -->
	<GameObject
		id="AlienWormhole"
		inheritFrom="AlienWormhole">
		<Behaviors>
			<LifetimeUpdate
				id="ModuleTag_LifeTime"
				xai:joinAction="Replace"
				MinLifetime="999999.0s"
				MaxLifetime="999999.0s"/>
		</Behaviors>
	</GameObject>

	<!-- Instantly Kill Tower -->
	<WeaponTemplate
		id="IonCannonFinalWeapon"
		Name="IonCannonFinalWeapon"
		AttackRange="50000"
		RadiusDamageAffects="SELF ALLIES ENEMIES NEUTRALS">
		<Nuggets>
			<DamageNugget
				Damage="28000"
				DamageTaperOff="1000"
				Radius="250"
				DamageType="CANNON"
				CylinderAOE="true">
				<DamageScalarDetails
					Scalar="2500%">
					<Filter
						Rule="NONE"
						Include="TIBERIUM"/>
				</DamageScalarDetails>
				<DamageScalarDetails
					Scalar="999999%">
					<Filter
						Rule="NONE">
						<IncludeThing>ABTower</IncludeThing>
					</Filter>
				</DamageScalarDetails>
			</DamageNugget>
			<WeaponOCLNugget
				WeaponOCL="OCL_IonCannonWeaponTreeCrusher"/>
			<WeaponOCLNugget
				WeaponOCL="OCL_IonCannonEMPField"/>
			<ParalyzeNugget
				Radius="500"
				DurationSeconds="10s"
				ParalyzeType="EMP"
				ParalyzeFX="FX_NODBuggyEmpHit"
				ForbiddenTargetObjectStatus="IN_STASIS">
				<SpecialObjectFilter
					Rule="ALL"
					Exclude="UNATTACKABLE INFANTRY CIVILIAN_BUILDING TIBERIUM TIBERIUM_FIELD"/>
			</ParalyzeNugget>
			<ParalyzeNugget
				Radius="500"
				DurationSeconds="10s"
				ParalyzeType="EMP"
				ParalyzeFX="FX_NODPummelerEMPHit"
				ForbiddenTargetObjectStatus="IN_STASIS">
				<SpecialObjectFilter
					Rule="NONE">
					<!-- NOD Cyborgs -->
					<IncludeThing>NODCyborgInfantry</IncludeThing>
					<IncludeThing>NODCyborgInfantrySquad</IncludeThing>
					<IncludeThing>NODPummeler</IncludeThing>
					<IncludeThing>NODPummelerSquad</IncludeThing>
					<IncludeThing>NODPummelerSquad_Veteran</IncludeThing>
					<IncludeThing>NODReaper</IncludeThing>
					<IncludeThing>NODCyborgCommando</IncludeThing>
					<IncludeThing>NODDecimator</IncludeThing>
					<IncludeThing>NODDecimatorSquad</IncludeThing>
					<IncludeThing>NODObliterator</IncludeThing>
					<IncludeThing>NODHijacker</IncludeThing>
				</SpecialObjectFilter>
			</ParalyzeNugget>
			<AttributeModifierNugget
				Radius="500"
				PartitionFilterTestType="CIRCLE"
				ForbiddenTargetObjectStatus="IN_STASIS"
				ForbiddenTargetModelCondition="USER_19"
				AttributeModifierName="AttributeModifier_PreventCrush">
				<SpecialObjectFilter
					Rule="ALL"
					Exclude="UNATTACKABLE INFANTRY AIRCRAFT CIVILIAN_BUILDING TIBERIUM TIBERIUM_FIELD"/>
			</AttributeModifierNugget>
			<DamageNugget
				Damage="1000000"
				Radius="500"
				CylinderAOE="true"
				DamageType="GRENADE"
				DeathType="EXTRA_7"
				DamageFXType="GDI_RIFLE"
				ForbiddenTargetObjectStatus="IN_STASIS"
				ForbiddenTargetModelCondition="LOCOMOTOR_TAXIING USER_19">
				<SpecialObjectFilter
					Rule="NONE"
					Include="AIRCRAFT">
					<!-- Beacon has AIRCRAFT KindOf as a workaround -->
					<ExcludeThing>MultiplayerBeacon</ExcludeThing>
					<ExcludeThing>AlienMultiplayerBeacon</ExcludeThing>
				</SpecialObjectFilter>
			</DamageNugget>
			<!-- For Alien Razorback -->
			<DamageNugget
				Damage="1000000"
				Radius="500"
				CylinderAOE="true"
				DamageType="GRENADE"
				DeathType="EXTRA_7"
				DamageFXType="GDI_RIFLE"
				ForbiddenTargetObjectStatus="IN_STASIS RIDER2"
				ForbiddenTargetModelCondition="USER_19">
				<SpecialObjectFilter
					Rule="NONE">
					<!-- Alien Flying Ground Units -->
					<IncludeThing>AlienRazorback</IncludeThing>
					<IncludeThing>AlienRazorback_Flying</IncludeThing>
				</SpecialObjectFilter>
			</DamageNugget>
			<SuppressionNugget
				Radius="750"
				Suppression="5000"
				DurationSeconds="7s"/>
		</Nuggets>
	</WeaponTemplate>

	<!-- Mission Objectives -->
	<MissionObjectiveList
		id="MissionObjectives">
		<!-- Defend the Alien Tower -->
		<MissionObjectiveTag
			Script="SCRIPT:Alien_1_5_Objective_1"
			Description="SCRIPT:Alien_1_5_Obj_1_Detail">
			<PresentationSettings
				ID="Alien_1_5_Obj_1"
				Dialog="MAA4_AlienAI01"
				UseDynamicZoom="False">
				<Duration>9s</Duration>
				<CameraStartAngle>30d</CameraStartAngle>
				<CameraEndAngle>55d</CameraEndAngle>
				<CameraFieldOfView>60d</CameraFieldOfView>
			</PresentationSettings>
		</MissionObjectiveTag>
		<!-- Construct a Signal Transmitter -->
		<MissionObjectiveTag
			Script="SCRIPT:Alien_1_5_Objective_2"
			Description="SCRIPT:Alien_1_5_Obj_2_Detail">
			<PresentationSettings
				ID="Alien_1_5_Obj_2"
				Dialog="MAA4_AlienAI05"
				UseDynamicZoom="False">
				<Duration>9s</Duration>
				<CameraStartAngle>25d</CameraStartAngle>
				<CameraEndAngle>-25d</CameraEndAngle>
				<CameraFieldOfView>35d</CameraFieldOfView>
			</PresentationSettings>
		</MissionObjectiveTag>
		<!-- Guide and protect the Mothership to the Tower -->
		<MissionObjectiveTag
			Script="SCRIPT:Alien_1_5_Objective_3"
			Description="SCRIPT:Alien_1_5_Obj_3_Detail">
			<PresentationSettings
				ID="Alien_1_5_Obj_3"
				Dialog="MAA4_AlienAI06"
				UseDynamicZoom="False">
				<Duration>5s</Duration>
				<CameraStartAngle>25d</CameraStartAngle>
				<CameraEndAngle>-25d</CameraEndAngle>
				<CameraFieldOfView>45d</CameraFieldOfView>
			</PresentationSettings>
		</MissionObjectiveTag>
		<!-- Destroy the GDI base -->
		<MissionObjectiveTag
			IsBonusObjective="true"
			Script="SCRIPT:Alien_1_3_BonusObjective_1"
			Description="SCRIPT:Alien_1_3_BonObj_1_Detail">
			<PresentationSettings
				ID="Alien_1_5_BonObj_1"
				Dialog="MAA3_AlienAI04">
				<Duration>5s</Duration>
				<CameraStartAngle>25d</CameraStartAngle>
				<CameraEndAngle>-25d</CameraEndAngle>
				<CameraFieldOfView>50d</CameraFieldOfView>
			</PresentationSettings>
		</MissionObjectiveTag>
	</MissionObjectiveList>
</AssetDeclaration>