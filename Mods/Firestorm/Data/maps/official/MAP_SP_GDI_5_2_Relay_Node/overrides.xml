	<!-- Lowered shroud Clearing range from 800 | Lowered speed from 20 | Increased health from 28000 -->
	<GameObject
		id="AlienMothership"
		inheritFrom="AlienMothership">
		<LocomotorSet
			Locomotor="AlienMothershipLocomotor"
			Condition="NORMAL"
			Speed="15.0"/>
		<ClientUpdates
			xai:joinAction="Remove"/>
		<Body>
			<ShieldBody
				id="ModuleTag_Body"
				xai:joinAction="Append"
				MaxHealth="100000"/>
		</Body>
		<VisionInfo
			VisionRange="350"
			ShroudClearingRange="150"/>
	</GameObject>

	<!-- Added Liquid Tiberium Bomb SP -->
	<GameObject
		id="PlayerSpellBook"
		inheritFrom="PlayerSpellBook">
		<Behaviors>
			<PlayerPowerManager
				id="ModuleTag_PlayerPowerManager_GDINuclearMissile"
				SpecialPowerTemplate="SpecialPowerGDINuclearMissile"/>
		</Behaviors>
	</GameObject>

	<!-- Increased broadcast range from 450 -->
	<GameObject
		id="NODDisruptionTower"
		inheritFrom="NODDisruptionTower">
		<Behaviors>
			<InvisibilityUpdate
				id="ModuleTag_Invisibility"
				xai:joinAction="Append"
				BroadcastRange="600"/>
			<InvisibilityUpdate
				id="ModuleTag_AdvInvisibility"
				xai:joinAction="Append"
				BroadcastRange="600"/>
		</Behaviors>
	</GameObject>

	<!-- Increased radius from 115 to 150 -->
	<WeaponTemplate
		id="AlienCrystalShieldWeaponTrigger"
		Name="AlienCrystalShieldWeaponTrigger"
		AttackRange="50000"
		AntiMask="ANTI_GROUND ANTI_STRUCTURE"
		RadiusDamageAffects="NOT_SIMILAR ALLIES ENEMIES NEUTRALS">
		<Nuggets>
			<ParalyzeNugget
				Radius="150"
				DurationSeconds="0.25s"
				ParalyzeType="USER_PARALYZE">
				<SpecialObjectFilter
					Rule="ANY"
					Include="VEHICLE INFANTRY STRUCTURE AIRCRAFT MINE">
					<!-- Paralyzing Ion Storms -->
					<IncludeThing>IonStorm</IncludeThing>
					<IncludeThing>IonStormTemporary</IncludeThing>
					<IncludeThing>IonRetributionIonStorm</IncludeThing>
					<IncludeThing>PlanetaryAssaultCarrierIonStorm</IncludeThing>
					<IncludeThing>TiberiumFieldIonStorm</IncludeThing>
					<!-- Beacon has AIRCRAFT KindOf as a workaround -->
					<ExcludeThing>MultiplayerBeacon</ExcludeThing>
					<ExcludeThing>AlienMultiplayerBeacon</ExcludeThing>
					<!-- Excluding some other objects -->
					<ExcludeThing>AlienCrystalShield</ExcludeThing>
					<ExcludeThing>AlienPhaseShield</ExcludeThing>
					<ExcludeThing>AlienTemporalWormhole</ExcludeThing>
					<ExcludeThing>AlienWormHole</ExcludeThing>
				</SpecialObjectFilter>
			</ParalyzeNugget>
			<AttributeModifierNugget
				Radius="150"
				PartitionFilterTestType="SPHERE"
				AttributeModifierName="AttributeModifier_AlienCrystalShield">
				<SpecialObjectFilter
					Rule="ANY"
					Include="VEHICLE INFANTRY STRUCTURE AIRCRAFT TIBERIUM MINE"
					Exclude="TIBERIUM_FIELD">
					<!-- Paralyzing Ion Storms -->
					<IncludeThing>IonStorm</IncludeThing>
					<IncludeThing>IonStormTemporary</IncludeThing>
					<IncludeThing>IonRetributionIonStorm</IncludeThing>
					<IncludeThing>PlanetaryAssaultCarrierIonStorm</IncludeThing>
					<IncludeThing>TiberiumFieldIonStorm</IncludeThing>
					<!-- Beacon has AIRCRAFT KindOf as a workaround -->
					<ExcludeThing>MultiplayerBeacon</ExcludeThing>
					<ExcludeThing>AlienMultiplayerBeacon</ExcludeThing>
					<!-- Excluding some other objects -->
					<ExcludeThing>AlienCrystalShield</ExcludeThing>
					<ExcludeThing>AlienPhaseShield</ExcludeThing>
					<ExcludeThing>AlienTemporalWormhole</ExcludeThing>
					<ExcludeThing>AlienWormHole</ExcludeThing>
				</SpecialObjectFilter>
			</AttributeModifierNugget>
			<TintObjectsNugget
				Radius="150"
				PreColorTime="0s"
				PostColorTime="0s"
				SustainedColorTime="0.25s"
				Frequency="0"
				Amplitude="0">
				<Color
					R="0.2"
					G="0"
					B="0.5"/>
			</TintObjectsNugget>
		</Nuggets>
	</WeaponTemplate>

	<!-- Don't deal damage to the Control Node -->
	<WeaponTemplate
		id="BlueTiberiumDeathWeapon"
		Name="BlueTiberiumDeathWeapon"
		AttackRange="150"
		AcceptableAimDelta="360d"
		ScatterRadius="40"
		ScatterLength="20"
		WeaponSpeed="999999"
		FireFX="FX_AlienZeusTiberiumBombHitBlue"
		ClipSize="1"
		ScatterIndependently="true">
		<ClipReloadTime
			MinSeconds="0.1s"
			MaxSeconds="0.1s"/>
		<Nuggets>
			<DamageNugget
				Damage="2000"
				Radius="30"
				DelayTimeSeconds="0.5s"
				DamageType="UNRESISTABLE"
				DeathType="EXPLODED">
				<SpecialObjectFilter
					Rule="ALL">
					<ExcludeThing>AlienControlNode</ExcludeThing>
				</SpecialObjectFilter>
				<DamageScalarDetails
					Scalar="1000%">
					<Filter
						Rule="NONE"
						Include="TIBERIUM"/>
				</DamageScalarDetails>
			</DamageNugget>
		</Nuggets>
	</WeaponTemplate>

