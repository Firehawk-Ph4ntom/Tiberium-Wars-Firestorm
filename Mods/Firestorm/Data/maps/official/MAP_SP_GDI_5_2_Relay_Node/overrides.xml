	<!-- Core Defender Override -->
	<!-- Using a special Weapon designed for the mission -->
	<GameObject
		id="NODDarkTwilight"
		inheritFrom="NODDarkTwilight">
		<DisplayName
			xmlns:xai="uri:ea.com:eala:asset:instance"
			xai:joinAction="Replace">Name:Core_Defender</DisplayName>
		<Behaviors>
			<WeaponSetUpdate
				id="ModuleTag_WeaponSetUpdate"
				xai:joinAction="Replace">
				<WeaponSlotHardpoint
					ID="1"
					AllowInterleavedFiring="true"
					InterleavedStyle="INTERLEAVE_RANDOM">
					<Weapon
						Template="NODDarkTwilightArtilleryNuclearCannon"/>
					<Weapon
						Template="NODDarkTwilightArtilleryNuclearCannonUpgraded"
						ObjectStatus="WEAPON_UPGRADED_01"/>
				</WeaponSlotHardpoint>
				<WeaponSlotHardpoint
					ID="2"
					AllowInterleavedFiring="true"
					InterleavedStyle="INTERLEAVE_RANDOM">
					<Weapon
						Template="NODDarkTwilightArtilleryNuclearCannon"/>
					<Weapon
						Template="NODDarkTwilightArtilleryNuclearCannonUpgraded"
						ObjectStatus="WEAPON_UPGRADED_01"/>
				</WeaponSlotHardpoint>
				<WeaponSlotHardpoint
					ID="3"
					AllowInterleavedFiring="true"
					InterleavedStyle="INTERLEAVE_RANDOM">
					<Weapon
						Template="NODDarkTwilightArtilleryNuclearCannon"/>
					<Weapon
						Template="NODDarkTwilightArtilleryNuclearCannonUpgraded"
						ObjectStatus="WEAPON_UPGRADED_01"/>
				</WeaponSlotHardpoint>
				<WeaponSlotHardpoint
					ID="4"
					AllowInterleavedFiring="true"
					InterleavedStyle="INTERLEAVE_RANDOM">
					<Weapon
						Template="NODDarkTwilightArtilleryNuclearCannon"/>
					<Weapon
						Template="NODDarkTwilightArtilleryNuclearCannonUpgraded"
						ObjectStatus="WEAPON_UPGRADED_01"/>
				</WeaponSlotHardpoint>
			</WeaponSetUpdate>
		</Behaviors>
	</GameObject>

	<!-- Increased Build Times -->
	<GameObject
		id="AlienPlanetaryAssaultCarrier"
