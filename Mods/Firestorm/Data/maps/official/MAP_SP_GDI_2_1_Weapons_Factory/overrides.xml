	<!-- Added AUTO_ACQUIRABLE_BY_AI KindOf -->
	<GameObject
		id="TiberiumSpikePVEGameMode"
		inheritFrom="TiberiumSpikePVEGameMode"
		KindOf="STRUCTURE SELECTABLE IMMOBILE CAN_CAST_REFLECTIONS FS_CASH_PRODUCER FS_TECHNOLOGY NOT_AUTOACQUIRABLE IGNORE_FOR_VICTORY NOT_SELLABLE NEUTRAL_TECH TIBERIUM_BASED FS_MONEY_STORAGE AUTO_ACQUIRABLE_BY_AI"/>

	<!-- Added a new Death effect -->
	<GameObject
		id="NOD_WeaponsLabFacility"
		inheritFrom="NOD_WeaponsLabFacility">
		<Draws>
			<ScriptedModelDraw
				id="ModuleTag_Draw"
				xai:joinAction="Append"
				OkToChangeModelColor="true"/>
		</Draws>
		<Behaviors>
			<FXListBehavior
				id="ModuleTag_FXList"
				xai:joinAction="Replace">
				<DieMuxData
					DeathTypes="ALL"/>
				<Event
					Index="onTransitionToDamaged"
					FX="FX_BuildDamaged_Large"/>
				<Event
					Index="onTransitionToReallyDamaged"
					FX="FX_BuildDamaged_Large"/>
				<Event
					Index="onTransitionToRubble"
					FX="FX_TibFacilityXplosion"/>
				<Event
					Index="onDeath"
					ForceUseDoFXObj="true"
					FX="FX_ScorchLarge"/>
			</FXListBehavior>
		</Behaviors>
	</GameObject>

