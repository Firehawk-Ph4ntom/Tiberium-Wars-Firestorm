	<!-- Accept both vehicle and infantry | Max Contain 6 | Increased Speed from 175 -->
	<GameObject
		id="NODCarryall"
		inheritFrom="NODCarryall">
		<LocomotorSet
			Locomotor="NODDropshipLocomotor"
			Condition="NORMAL"
			Speed="200.0" />
		<LocomotorSet
			Locomotor="BasicHelicopterTaxiLocomotor"
			Condition="TAXIING"
			Speed="200.0" />
		<Behaviors>
			<HordeTransportContain
				id="ModuleTag_Contain"
				xai:joinAction="Replace"
				ObjectStatusOfContained="UNSELECTABLE ENCLOSED"
				ContainMax="6"
				Slots="6"
				AllowEnemiesInside="false"
				AllowAlliesInside="true"
				AllowNeutralInside="true"
				AllowOwnPlayerInsideOverride="true"
				ShowPips="true"
				EnterSound="VehicleEnter"
				ExitSound="VehicleExit"
				KillPassengersOnDeath="true"
				FlyOffMapOnEmpty="true">
				<PassengerFilter
					Rule="ANY"
					Include="INFANTRY VEHICLE" />
				<DieMuxData
					DeathTypes="ALL" />
				<PassengerData
					BonePrefix="BONEGARRISON">
					<Filter
						Rule="ANY"
						Include="INFANTRY" />
				</PassengerData>
				<PassengerData
					BonePrefix="BONETANKGARRISON">
					<Filter
						Rule="ANY"
						Include="VEHICLE" />
				</PassengerData>
				<MemberTemplateStatusInfo
					ThingTemplate="GDISniper"
					ObjectStatus="CAN_SPOT_FOR_BOMBARD"/>
				<MemberTemplateStatusInfo
					ThingTemplate="GDIZoneTrooper"
					ObjectStatus="CAN_SPOT_FOR_BOMBARD"/>
				<MemberTemplateStatusInfo
					ThingTemplate="GDIZoneRaider"
					ObjectStatus="CAN_SPOT_FOR_BOMBARD"/>
				<MemberTemplateStatusInfo
