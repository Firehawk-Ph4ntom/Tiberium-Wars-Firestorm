	<!-- Increased health from 1000 to 3000 | Increased speed from 80 to 120 | Replaced Manipulator Device with a Proton Cannon | Removed CAN_PLACE_MANIPULATOR KindOf | Increased Object Store Radius from 50 -->
	<GameObject
		id="AlienMastermindPVEGameMode"
		inheritFrom="AlienMastermindPVEGameMode"
		KindOf="SELECTABLE CAN_ATTACK ATTACK_NEEDS_LINE_OF_SIGHT CAN_CAST_REFLECTIONS INFANTRY SCORE UNIQUE_UNIT PATH_THROUGH_INFANTRY HEALED_BY_TIBERIUM TIBERIUM_BASED SKIRMISH_AI_DONT_GARRISON CAN_BE_FAVORITE_UNIT">
		<LocomotorSet
			Locomotor="HumanLocomotor"
			Condition="NORMAL"
			Speed="120"/>
		<Behaviors>
			<WeaponSetUpdate
				id="ModuleTag_WeaponSetUpdate"
				xai:joinAction="Replace">
				<WeaponSlotHardpoint
					ID="1">
					<Weapon
						Ordering="PRIMARY_WEAPON"
						Template="AlienMastermindProtonCannon"/>
				</WeaponSlotHardpoint>
			</WeaponSetUpdate>
			<!-- Removed Manipulator Device -->
			<SpecialPower
				id="ModuleTag_ManipulatorDevice"
				xai:joinAction="Remove"/>
			<ActivateModuleSpecialPower
				id="ModuleTag_ManipulatorDeviceUpdate"
				xai:joinAction="Remove"/>
			<AISpecialPowerUpdate
				id="ModuleTag_ManipulatorDeviceAI"
				xai:joinAction="Remove"/>
			<StoreObjectsSpecialPowerUpdate
				id="ModuleTag_StoreObjectsSpecialPowerUpdate"
				xai:joinAction="Append"
				Radius="200"/>
		</Behaviors>
		<AI>
			<AIUpdate
				id="ModuleTag_AI"
				xai:joinAction="Replace"
				AutoAcquireEnemiesWhenIdle="YES"
				AILuaEventsList="AlienMastermindFunctions">
				<UnitAITargetChooserData
					CanPickDynamicTargets="true"
					TargetingCompareList="CompleteUnitTargetingCompareList"/>
			</AIUpdate>
		</AI>
		<Body>
			<ActiveBody
				id="ModuleTag_Body"
				xai:joinAction="Replace"
				MaxHealth="3000"/>
		</Body>
	</GameObject>

	<SpecialPowerTemplate
		id="SpecialPowerMastermindTeleportObjectSelect"
		TargetType="LOCATION"
		Flags="NEEDS_OBJECT_FILTER LIMIT_DISTANCE NO_FORBIDDEN_MODEL_STATES TARGET_NEEDS_OBJECT_STATUS IGNORE_SELF_IN_NEEDED_OBJECT_FILTER"
		RadiusCursorRadius="200"
		DisallowedTargetModelStates="LOCOMOTOR_NORMAL_UPGRADED USER_50"
		DisallowedTargetObjectStatus="INSIDE_GARRISON AIRBORNE_TARGET OUT_OF_PHASE POWERED_DOWN_EMP IN_STASIS"
		MaxCastRange="999999"
		WaypointModeTerminal="false"
		EvaEventToPlayWhenSelectingTarget="SelectSpecialPowerTarget"
		NameOfVoiceNameToUseAsInitiateIntendToDoVoice="TeleportObject">
		<ObjectFilter
			Rule="ANY"
			Relationship="ALLIES"
			Include="INFANTRY VEHICLE"
			Exclude="HUGE_VEHICLE">
			<ExcludeThing>GDIArmadilloDeployed</ExcludeThing>
