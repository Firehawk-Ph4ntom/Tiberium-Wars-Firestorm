	<!-- Affects Mastermind -->
	<SpecialPowerTemplate
		id="SpecialPower_PhaseField"
		TargetType="LOCATION"
		Flags="NEEDS_OBJECT_FILTER IS_PLAYER_POWER SHARED_SYNC IGNORE_MAP_EXTENTS WATER_OK TARGET_NEEDS_OBJECT_STATUS"
