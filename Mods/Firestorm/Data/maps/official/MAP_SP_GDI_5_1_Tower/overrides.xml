	<WeaponTemplate
		id="AlienPhaseFieldWeaponTrigger"
		Name="AlienPhaseFieldWeaponTrigger"
		RadiusDamageAffects="ALLIES"
		AttackRange="50000">
		<Nuggets>
			<AttributeModifierNugget
				Radius="100"
				PartitionFilterTestType="CIRCLE"
				ForbiddenTargetObjectStatus="IN_STASIS"
				AttributeModifierName="AttributeModifier_AlienPhaseField">
				<SpecialObjectFilter
					Rule="NONE"
					Relationship="ALLIES"
					Include="VEHICLE">
					<IncludeThing>AlienMastermind</IncludeThing>
				</SpecialObjectFilter>
			</AttributeModifierNugget>
		</Nuggets>
	</WeaponTemplate>

	<WeaponTemplate
		id="AlienMastermindProtonCannon"
		Name="AlienMastermindProtonCannon"
		AttackRange="200"
		AcceptableAimDelta="10d"
		WeaponSpeed="1000"
		FireFX="FX_AlienHunterPlasmaDiskFire"
		FireVeteranFX="FX_AlienHunterPlasmaDiskFireHeroic"
		ForbiddenFiringObjectStatus="USER_PARALYZED"
		ClipSize="1"
		ReAcquireDetailType="PRE_FIRE">
		<ClipReloadTime
			MinSeconds="0.05s"
			MaxSeconds="0.05s"/>
		<Nuggets>
			<ProjectileNugget
				WarheadTemplate="AlienMastermindProtonCannonWarhead"
				ProjectileTemplate="AlienHunterPlasmaBolt">
				<VeterancyProjectiles
					VeterancyLevel="HEROIC"
					ProjectileTemplate="AlienHunterPlasmaBolt_Veteran"/>
			</ProjectileNugget>
		</Nuggets>
	</WeaponTemplate>

	<WeaponTemplate
		id="AlienMastermindProtonCannonWarhead"
		Name="AlienMastermindProtonCannonWarhead"
		RadiusDamageAffects="ENEMIES NEUTRALS NOT_SIMILAR"
