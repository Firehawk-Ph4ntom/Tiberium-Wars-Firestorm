<AssetDeclaration xmlns="uri:ea.com:eala:asset" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xi="http://www.w3.org/2001/XInclude" xmlns:xai="uri:ea.com:eala:asset:instance">
	<Includes>
		<!-- Base Object -->
		<Include type="instance" source="DATA:Firestorm\Data\Data\Misc\BaseObjects\BaseVehicle.xml"/>
	</Includes>
	<GameObject id="MutantAPCDeployedHusk" inheritFrom="BaseVehicle" Side="GDI" CommandSet="EmptyCommandSet" KindOf="CAN_CAST_REFLECTIONS NOT_AUTOACQUIRABLE IMMOBILE" EditorName="MutantAPCDeployedHusk" EditorSorting="MISC_MAN_MADE">
		<DisplayName xmlns:xai="uri:ea.com:eala:asset:instance" xai:joinAction="Replace">Name:MutantAPC</DisplayName>
		<ArmorSet Armor="NoArmor"/>
		<Draws>
			<ScriptedModelDraw id="ModuleTag_Draw" OkToChangeModelColor="true">
				<ModelConditionState ParseCondStateType="PARSE_DEFAULT">
					<Model Name="MUAPC_SKN"/>
					<Texture Original="GB_Suv" New="GU_Suv_D"/>
					<Texture Original="MUAPC" New="MUAPC_D"/>
					<Texture Original="MUAPCBunker" New="MUAPCBunker_D"/>
					<ParticleSysBone BoneName="FX_FIRE" FXParticleSystemTemplate="GDIDebrisSmallFire" FollowBone="true"/>
					<ParticleSysBone BoneName="FX_FIRE" FXParticleSystemTemplate="GDIDebrisSmallFireDistortion" FollowBone="true"/>
					<ParticleSysBone BoneName="FX_FIRE" FXParticleSystemTemplate="GDIDebrisSmallSmoke" FollowBone="true"/>
					<ParticleSysBone BoneName="MAINBONE" FXParticleSystemTemplate="GDIDebrisSmallFire" FollowBone="true"/>
					<ParticleSysBone BoneName="MAINBONE" FXParticleSystemTemplate="GDIDebrisSmallFireDistortion" FollowBone="true"/>
					<ParticleSysBone BoneName="MAINBONE" FXParticleSystemTemplate="GDIDebrisSmallSmoke" FollowBone="true"/>
					<ParticleSysBone BoneName="BONE_TIRERF" FXParticleSystemTemplate="GDIDebrisSmallSmoke" FollowBone="true"/>
				</ModelConditionState>
				<AnimationState ParseCondStateType="PARSE_DEFAULT" Flags="START_FRAME_LAST">
					<Animation AnimationName="MUAPC_UPAK" AnimationMode="MANUAL" AnimationBlendTime="0"/>
				</AnimationState>
			</ScriptedModelDraw>
			<ScriptedModelDraw id="ModuleTag_DrawSpeakers" AttachToBoneInAnotherModule="BONE_ROOF">
				<ModelConditionState ParseCondStateType="PARSE_DEFAULT">
					<Model Name="NURECKONERSPEAKERS_DUMMYSKN"/>
				</ModelConditionState>
				<ModelConditionState ParseCondStateType="PARSE_NORMAL" ConditionsYes="USER_1">
					<Model Name="NURECKONERSPEAKERS_SKN"/>
					<Texture Original="NUSuv" New="NUSuv_D"/>
				</ModelConditionState>
				<AnimationState ParseCondStateType="PARSE_DEFAULT"/>
				<AnimationState ParseCondStateType="PARSE_NORMAL" ConditionsYes="USER_1">
					<Script> CurDrawableHideSubObject("TV") </Script>
				</AnimationState>
			</ScriptedModelDraw>
			<ScriptedModelDraw id="ModuleTag_DrawRadar" AttachToBoneInAnotherModule="RADAR">
				<ModelConditionState ParseCondStateType="PARSE_DEFAULT">
					<Model Name="MUAPCRADAR_SKN"/>
					<Texture Original="GB_Suv" New="GU_Suv_D"/>
				</ModelConditionState>
			</ScriptedModelDraw>
		</Draws>
		<Behaviors>
			<Physics id="ModuleTag_Physics"/>
			<LifetimeUpdate id="ModuleTag_LifeTime" MinLifetime="0.1s" MaxLifetime="0.1s"/>
			<SlowDeath id="ModuleTag_Death" SinkDelay="3s" SinkRate="1.0" DestructionDelay="10s">
				<DieMuxData DeathTypes="ALL"/>
			</SlowDeath>
			<ModelConditionUpgrade id="ModuleTag_PropagandaModelCondition" AddConditionFlags="USER_1">
				<TriggeredBy>Upgrade_PropagandaBuff</TriggeredBy>
			</ModelConditionUpgrade>
			<SquishCollide id="DefaultSquishCollide" xai:joinAction="Remove"/>
			<AutoHealBehavior id="Upgrade_HeroicHeal" xai:joinAction="Remove"/>
			<LevelUpUpgrade id="ModuleTag_LevelUpUpgrade_Veteran" xai:joinAction="Remove"/>
			<LevelUpUpgrade id="ModuleTag_LevelUpUpgrade_Elite" xai:joinAction="Remove"/>
			<LevelUpUpgrade id="ModuleTag_LevelUpUpgrade_Heroic" xai:joinAction="Remove"/>
			<InvisibilityUpdate id="ModuleTag_Invisibility" xai:joinAction="Remove"/>
			<StealthUpgrade id="ModuleTag_InvisibilityTrigger" xai:joinAction="Remove"/>
			<StancesBehavior id="ModuleTag_Stance" xai:joinAction="Remove"/>
		</Behaviors>
		<AI>
			<AIUpdate id="ModuleTag_AI" AutoAcquireEnemiesWhenIdle="NO"/>
		</AI>
		<Body>
			<ActiveBody id="ModuleTag_Body" MaxHealth="100"/>
		</Body>
		<EvaEvents EvaEventPromotedOwner="" EvaEnemyObjectSightedEvent="" EvaEventDetectedEnemy="" EvaEventDieOwner=""/>
		<VisionInfo VisionRange="25" ShroudClearingRange="25"/>
	</GameObject>
</AssetDeclaration>