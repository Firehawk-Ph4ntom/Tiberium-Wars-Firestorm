<AssetDeclaration xmlns="uri:ea.com:eala:asset" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xi="http://www.w3.org/2001/XInclude" xmlns:xai="uri:ea.com:eala:asset:instance">
	<Includes>
		<!-- Base Object -->
		<Include type="instance" source="GDIRepairDrone.xml"/>
	</Includes>
	<GameObject id="GDIMRTRepairDrone" inheritFrom="GDIRepairDrone" EditorName="GDIMRTRepairDrone">
		<LocomotorSet Speed="150" Locomotor="GDIRepairDroneLocomotor"/>
		<Draws>
			<ScriptedModelDraw id="ModuleTag_Draw" xai:joinAction="Replace" InitialRecoilSpeed="0.1" MaxRecoilDistance="0.1" RecoilDamping="2.0" RecoilSettleSpeed="3.0" OkToChangeModelColor="true" ExtraPublicBone="FXWEAPON01 FXWEAPON02">
				<ModelConditionState ParseCondStateType="PARSE_DEFAULT">
					<Model Name="GURPRDRN_SKN_FS"/>
					<Texture Original="GURprDrone" New="GURprDroneNew_VS"/>
					<WeaponFireFXBone WeaponSlotID="1" WeaponSlotType="PRIMARY_WEAPON" BoneName="FXWeapon"/>
					<WeaponRecoilBone WeaponSlotID="1" WeaponSlotType="PRIMARY_WEAPON" BoneName="FXWeapon"/>
					<WeaponMuzzleFlash WeaponSlotID="1" WeaponSlotType="PRIMARY_WEAPON" BoneName="FXWeapon"/>
					<WeaponLaunchBone WeaponSlotID="1" WeaponSlotType="PRIMARY_WEAPON" BoneName="FXWeapon"/>
					<Turret TurretNameKey="UG_TURRET" TurretID="1"/>
				</ModelConditionState>
				<ModelConditionState ParseCondStateType="PARSE_NORMAL" ConditionsYes="USER_1 USER_2">
					<Model Name="GURPRDRNUGAMMO_SKN_FS"/>
				</ModelConditionState>
				<AnimationState ParseCondStateType="PARSE_DEFAULT" Flags="RESTART_ANIM_WHEN_COMPLETE" AllowRepeatInRandomPick="true">
					<Animation AnimationName="GURPRDRN_IDLA" AnimationMode="ONCE"/>
				</AnimationState>
				<AnimationState ParseCondStateType="PARSE_NORMAL" ConditionsYes="DYING" Flags="RANDOMSTART">
					<Animation AnimationName="GURPRDRN_RPRA" AnimationMode="LOOP"/>
				</AnimationState>
				<AnimationState ParseCondStateType="PARSE_NORMAL" ConditionsYes="ATTACHED" Flags="RANDOMSTART">
					<Animation AnimationName="GURPRDRN_RPRA" AnimationMode="LOOP"/>
					<ParticleSysBone BoneName="B_Drone03" FXParticleSystemTemplate="GDIRepairDroneFlash" FollowBone="true"/>
					<ParticleSysBone BoneName="B_Drone03" FXParticleSystemTemplate="GDIRepairDroneSparks" FollowBone="true"/>
				</AnimationState>
				<AnimationState ParseCondStateType="PARSE_NORMAL" ConditionsYes="AFFECTED_BY_EMP">
					<Animation AnimationName="GURPRDRN_IDLA" AnimationMode="MANUAL" AnimationBlendTime="15"/>
				</AnimationState>
				<AnimationState ParseCondStateType="PARSE_NORMAL" ConditionsYes="ACCELERATE MOVING" Flags="RANDOMSTART">
					<Animation AnimationName="GURPRDRN_ACCL" AnimationMode="ONCE" Distance="30"/>
				</AnimationState>
				<AnimationState ParseCondStateType="PARSE_NORMAL" ConditionsYes="DECELERATE MOVING" Flags="RANDOMSTART">
					<Animation AnimationName="GURPRDRN_DECL" AnimationMode="ONCE" Distance="30"/>
				</AnimationState>
				<AnimationState ParseCondStateType="PARSE_NORMAL" ConditionsYes="MOVING" Flags="RANDOMSTART">
					<Animation AnimationName="GURPRDRN_MOVA" AnimationMode="LOOP" Distance="30" AnimationPriority="30"/>
				</AnimationState>
				<AnimationState ParseCondStateType="PARSE_NORMAL" ConditionsYes="ATTACKING" Flags="RANDOMSTART">
					<Animation AnimationName="GURPRDRN_IDLA" AnimationMode="LOOP" AnimationPriority="30"/>
				</AnimationState>
			</ScriptedModelDraw>
			<!-- Used xai Replace here so that Repair Drone can show it's model properly in WB -->
			<TracerModelDraw id="ModuleTag_TracerDraw" xai:joinAction="Replace" MinLength="50" MaxLength="50" Width="3" MinSpeed="30" MaxSpeed="30" SpreadAngle="2" MinTracersPerFrame="0.2" MaxTracersPerFrame="0.3" FrameLifeTime="35" Texture="FXTracerGDI" TracerHitFx="FX_BulletHitLargeGDI" UseAdditiveBlending="true">
				<HeadColor r="1.0" g="1.0" b="1.0" a="1.0" />
				<TailColor r="0.0" g="0.0" b="0.0" a="0.0" />
				<ObjectStatusValidation ForbiddenStatus="WEAPON_UPGRADED_02" RequiredStatus="WEAPON_UPGRADED_01"/>
			</TracerModelDraw>
			<TracerModelDraw id="ModuleTag_TracerDrawHEAmmo" xai:joinAction="Replace" MinLength="50" MaxLength="50" Width="3" MinSpeed="30" MaxSpeed="30" SpreadAngle="2" MinTracersPerFrame="0.2" MaxTracersPerFrame="0.3" FrameLifeTime="35" Texture="FXTracerGDIAPAmmo" TracerHitFx="FX_GDIHEAmmoExplosion" UseAdditiveBlending="true">
				<HeadColor r="1.0" g="1.0" b="1.0" a="1.0" />
				<TailColor r="0.0" g="0.0" b="0.0" a="0.0" />
				<ObjectStatusValidation ForbiddenStatus="RIDER1" RequiredStatus="WEAPON_UPGRADED_01"/>
			</TracerModelDraw>
		</Draws>
		<Behaviors>
			<SlavedUpdate id="ModuleTag_SlavedUpdate" xai:joinAction="Append" LeashRange="100" GuardMaxRange="100" StayOnSameLayerAsMaster="true"/>
			<PassiveAreaEffectBehavior id="ModuleTag_PassiveEffectBehavior" xai:joinAction="Replace" HealingPointsPerSecond="100" HealFX="FX_Repair" AffectAttached="true" AffectUnderAttack="true">
				<AllowFilter Rule="ANY" Relationship="ALLIES" Include="VEHICLE STRUCTURE" Exclude="AIRCRAFT">
					<!-- NOD Cyborgs -->
					<IncludeThing>NODCyborgInfantry</IncludeThing>
					<IncludeThing>NODPummeler</IncludeThing>
					<IncludeThing>NODReaper</IncludeThing>
					<IncludeThing>NODCyborgCommando</IncludeThing>
					<IncludeThing>NODDecimator</IncludeThing>
					<IncludeThing>NODObliterator</IncludeThing>
					<IncludeThing>NODHijacker</IncludeThing>
					<!-- Air Vehicle Transports -->
					<IncludeThing>GDIV35Ox_SummonedForVehicle</IncludeThing>
					<IncludeThing>NODCarryallVehicle</IncludeThing>
				</AllowFilter>
			</PassiveAreaEffectBehavior>
			<AttachUpdate id="ModuleTag_AttachUpdate" xai:joinAction="Replace" ParentStatus="UNDERGOING_REPAIR" Range="100" CloseEnoughRange="20" InitialAttachDelay="0.5s" Flags="FIND_BEST_PARENT UNCONTAINED_ONLY ONE_ATTACH_PER_PARENT" Teleport="false" DetachWhenParentHealed="true" DetachWhenParentOutOfSlavedRange="true" RequireFullyHealedToDetach="true" ScanForNewParentWhenDetached="true" CanAttachToHordeMembers="true">
				<ObjectFilter Rule="ANY" Relationship="ALLIES" Include="VEHICLE STRUCTURE" Exclude="AIRCRAFT">
					<!-- NOD Cyborgs -->
					<IncludeThing>NODCyborgInfantry</IncludeThing>
					<IncludeThing>NODPummeler</IncludeThing>
					<IncludeThing>NODReaper</IncludeThing>
					<IncludeThing>NODCyborgCommando</IncludeThing>
					<IncludeThing>NODDecimator</IncludeThing>
					<IncludeThing>NODObliterator</IncludeThing>
					<IncludeThing>NODHijacker</IncludeThing>
					<!-- Air Vehicle Transports -->
					<IncludeThing>GDIV35Ox_SummonedForVehicle</IncludeThing>
					<IncludeThing>NODCarryallVehicle</IncludeThing>
				</ObjectFilter>
			</AttachUpdate>
		</Behaviors>
	</GameObject>
</AssetDeclaration>