<AssetDeclaration xmlns="uri:ea.com:eala:asset" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xi="http://www.w3.org/2001/XInclude" xmlns:xai="uri:ea.com:eala:asset:instance">
	<Includes>
		<!-- Base Object -->
		<Include type="instance" source="DATA:Firestorm\Data\Data\Misc\BaseObjects\BaseVehicle.xml"/>
	</Includes>
	<GameObject id="GDIArmadilloDeployedHusk" inheritFrom="BaseVehicle" Side="GDI" CommandSet="EmptyCommandSet" KindOf="CAN_CAST_REFLECTIONS NOT_AUTOACQUIRABLE IMMOBILE" EditorName="GDIArmadilloDeployedHusk" EditorSorting="MISC_MAN_MADE">
		<DisplayName xmlns:xai="uri:ea.com:eala:asset:instance" xai:joinAction="Replace">Name:GDIArmadillo</DisplayName>
		<ArmorSet Armor="NoArmor"/>
		<Draws>
			<ScriptedModelDraw id="ModuleTag_Draw" OkToChangeModelColor="true">
				<ModelConditionState ParseCondStateType="PARSE_DEFAULT">
					<Model Name="GUARMADILLO_SKNR"/>
					<Texture Original="GUArmadillo" New="GUArmadillo_D"/>
					<ParticleSysBone BoneName="CHASSIS" FXParticleSystemTemplate="GDIDebrisSmallFire" FollowBone="true"/>
					<ParticleSysBone BoneName="CHASSIS" FXParticleSystemTemplate="GDIDebrisSmallFireDistortion" FollowBone="true"/>
					<ParticleSysBone BoneName="CHASSIS" FXParticleSystemTemplate="GDIDebrisSmallSmoke" FollowBone="true"/>
					<ParticleSysBone BoneName="NONE" FXParticleSystemTemplate="GDIMammothHulkFire" FollowBone="true"/>
					<ParticleSysBone BoneName="NONE" FXParticleSystemTemplate="GDIMammothHulkFireGlow" FollowBone="true"/>
					<ParticleSysBone BoneName="NONE" FXParticleSystemTemplate="GDIMammothHulkFireDistortion" FollowBone="true"/>
					<ParticleSysBone BoneName="NONE" FXParticleSystemTemplate="GDIMammothHulkSmoke" FollowBone="true"/>
				</ModelConditionState>
				<AnimationState ParseCondStateType="PARSE_DEFAULT" Flags="START_FRAME_LAST">
					<Animation AnimationName="GUARMADILLO_UPAK" AnimationMode="MANUAL" AnimationBlendTime="0"/>
				</AnimationState>
			</ScriptedModelDraw>
			<ScriptedModelDraw id="ModuleTag_DrawWeapon" AttachToBoneInAnotherModule="CHASSIS">
				<ModelConditionState ParseCondStateType="PARSE_DEFAULT">
					<Model Name="GUARMADILLOGUN_SKNR"/>
					<Texture Original="GUArmadillo" New="GUArmadillo_D"/>
				</ModelConditionState>
				<AnimationState ParseCondStateType="PARSE_DEFAULT"/>
			</ScriptedModelDraw>
		</Draws>
		<Behaviors>
			<Physics id="ModuleTag_Physics"/>
			<LifetimeUpdate id="ModuleTag_LifeTime" MinLifetime="0.1s" MaxLifetime="0.1s"/>
			<SlowDeath id="ModuleTag_Death" SinkDelay="3s" SinkRate="1.0" DestructionDelay="10s">
				<DieMuxData DeathTypes="ALL"/>
			</SlowDeath>
			<SubObjectsUpgrade id="ModuleTag_ShowSubObjectsHEAmmo" ShowSubObjects="APC_UGAB">
				<TriggeredBy>Upgrade_GDIHEAmmo</TriggeredBy>
			</SubObjectsUpgrade>
			<SquishCollide id="DefaultSquishCollide" xai:joinAction="Remove"/>
			<AutoHealBehavior id="Upgrade_HeroicHeal" xai:joinAction="Remove"/>
			<LevelUpUpgrade id="ModuleTag_LevelUpUpgrade_Veteran" xai:joinAction="Remove"/>
			<LevelUpUpgrade id="ModuleTag_LevelUpUpgrade_Elite" xai:joinAction="Remove"/>
			<LevelUpUpgrade id="ModuleTag_LevelUpUpgrade_Heroic" xai:joinAction="Remove"/>
			<InvisibilityUpdate id="ModuleTag_Invisibility" xai:joinAction="Remove"/>
			<StealthUpgrade id="ModuleTag_InvisibilityTrigger" xai:joinAction="Remove"/>
			<StancesBehavior id="ModuleTag_Stance" xai:joinAction="Remove"/>
		</Behaviors>
		<AI>
			<AIUpdate id="ModuleTag_AI" AutoAcquireEnemiesWhenIdle="NO" AILuaEventsList="GDIArmadilloDeployedFunctions"/>
		</AI>
		<Body>
			<ActiveBody id="ModuleTag_Body" MaxHealth="2000"/>
		</Body>
		<EvaEvents EvaEventPromotedOwner="" EvaEnemyObjectSightedEvent="" EvaEventDetectedEnemy="" EvaEventDieOwner=""/>
		<VisionInfo VisionRange="25" ShroudClearingRange="25"/>
	</GameObject>
	<!-- Upgraded Variant -->
	<GameObject id="GDIArmadilloDeployedHuskAdaptiveArmor" inheritFrom="GDIArmadilloDeployedHusk" EditorName="GDIArmadilloDeployedHuskAdaptiveArmor">
		<Draws>
			<ScriptedModelDraw id="ModuleTag_Draw" xai:joinAction="Replace" OkToChangeModelColor="true">
				<ModelConditionState ParseCondStateType="PARSE_DEFAULT">
					<Model Name="GUARMADILLO_SKNRADAR"/>
					<Texture Original="GUArmadillo" New="GUArmadillo_D"/>
					<ParticleSysBone BoneName="CHASSIS" FXParticleSystemTemplate="GDIDebrisSmallFire" FollowBone="true"/>
					<ParticleSysBone BoneName="CHASSIS" FXParticleSystemTemplate="GDIDebrisSmallFireDistortion" FollowBone="true"/>
					<ParticleSysBone BoneName="CHASSIS" FXParticleSystemTemplate="GDIDebrisSmallSmoke" FollowBone="true"/>
				</ModelConditionState>
				<AnimationState ParseCondStateType="PARSE_DEFAULT" Flags="START_FRAME_LAST">
					<Animation AnimationName="GUARMADILLO_UPAK" AnimationMode="MANUAL" AnimationBlendTime="0"/>
				</AnimationState>
			</ScriptedModelDraw>
			<ScriptedModelDraw id="ModuleTag_DrawWeapon" xai:joinAction="Replace" AttachToBoneInAnotherModule="CHASSIS">
				<ModelConditionState ParseCondStateType="PARSE_DEFAULT">
					<Model Name="GUARMADILLOGUN_SKNRADAR"/>
					<Texture Original="GUArmadillo" New="GUArmadillo_D"/>
				</ModelConditionState>
				<AnimationState ParseCondStateType="PARSE_DEFAULT"/>
			</ScriptedModelDraw>
		</Draws>
	</GameObject>
</AssetDeclaration>