<AssetDeclaration xmlns="uri:ea.com:eala:asset" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xai="uri:ea.com:eala:asset:instance">
	<!-- Normal Shredder Turret Projectile -->
	<GameObject id="NODShredderTurretShell" Side="NOD" EditorSorting="SYSTEM" KindOf="PROJECTILE NO_COLLIDE HIDE_IF_FOGGED" EditorName="NODShredderTurretShell">
		<ArmorSet Armor="NoArmor"/>
		<Draws>
			<ScriptedModelDraw id="ModuleTag_Draw">
				<ModelConditionState ParseCondStateType="PARSE_DEFAULT">
					<Model Name="NBShredderProj"/>
				</ModelConditionState>
			</ScriptedModelDraw>
		</Draws>
		<Behaviors>
			<FXListBehavior id="ModuleTag_FXList">
				<DieMuxData DeathTypes="ALL"/>
				<Event FX="FX_NOD_ShredderHit"/>
			</FXListBehavior>
			<DestroyDie id="ModuleTag_Die">
				<DieMuxData DeathTypes="ALL"/>
			</DestroyDie>
			<BezierProjectile id="ModuleTag_BezierProjectile" FirstPercentIndent="33%" SecondPercentIndent="66%" FlightPathAdjustDistPerSecond="300" CurveFlattenMinDist="300" DetonateCallsKill="true" OrientToFlightPath="true"/>
		</Behaviors>
		<Body>
			<ActiveBody id="ModuleTag_Body" MaxHealth="100.0"/>
		</Body>
	</GameObject>
	<!-- Heroic Shredder Turret Projectile -->
	<GameObject id="NODShredderTurretShellHeroic" inheritFrom="NODShredderTurretShell" EditorName="NODShredderTurretShellHeroic">
		<Draws>
			<ScriptedModelDraw id="ModuleTag_Draw" xai:joinAction="Replace">
				<ModelConditionState ParseCondStateType="PARSE_DEFAULT">
					<Model Name="NBShredderProj"/>
					<Texture Original="NBShredderProj" New="NBShredderProjHeroic"/>
				</ModelConditionState>
			</ScriptedModelDraw>
		</Draws>
		<Behaviors>
			<FXListBehavior id="ModuleTag_FXList" xai:joinAction="Replace">
				<DieMuxData DeathTypes="ALL"/>
				<Event FX="FX_NOD_ShredderHitHeroic"/>
			</FXListBehavior>
		</Behaviors>
	</GameObject>
	<!-- Normal Combat Engineer Projectile -->
	<GameObject id="GDICombatEngineerShotgunShell" inheritFrom="NODShredderTurretShell" Side="GDI" EditorName="GDICombatEngineerShotgunShell">
		<Behaviors>
			<FXListBehavior id="ModuleTag_FXList" xai:joinAction="Replace">
				<DieMuxData DeathTypes="ALL"/>
				<Event FX="FX_GDICombatEngineerShellHit"/>
			</FXListBehavior>
		</Behaviors>
	</GameObject>
	<!-- Heroic Combat Engineer Projectile -->
	<GameObject id="GDICombatEngineerShotgunShellHeroic" inheritFrom="GDICombatEngineerShotgunShell" EditorName="GDICombatEngineerShotgunShellHeroic">
		<Draws>
			<ScriptedModelDraw id="ModuleTag_Draw" xai:joinAction="Replace">
				<ModelConditionState ParseCondStateType="PARSE_DEFAULT">
					<Model Name="NBShredderProj"/>
					<Texture Original="NBShredderProj" New="NBShredderProjHeroic"/>
				</ModelConditionState>
			</ScriptedModelDraw>
		</Draws>
		<Behaviors>
			<FXListBehavior id="ModuleTag_FXList" xai:joinAction="Replace">
				<DieMuxData DeathTypes="ALL"/>
				<Event FX="FX_GDICombatEngineerShellHitHeroic"/>
			</FXListBehavior>
		</Behaviors>
	</GameObject>
	<!-- Upgraded Combat Engineer Projectile -->
	<GameObject id="GDICombatEngineerShotgunShellHEAmmo" inheritFrom="GDICombatEngineerShotgunShell" EditorName="GDICombatEngineerShotgunShellHEAmmo">
		<Behaviors>
			<FXListBehavior id="ModuleTag_FXList" xai:joinAction="Replace">
				<DieMuxData DeathTypes="ALL"/>
				<Event FX="FX_GDICombatEngineerShellHitHEAmmo"/>
			</FXListBehavior>
		</Behaviors>
	</GameObject>
	<!-- Heroic Upgraded Combat Engineer Projectile -->
	<GameObject id="GDICombatEngineerShotgunShellHEAmmoHeroic" inheritFrom="GDICombatEngineerShotgunShellHeroic" EditorName="GDICombatEngineerShotgunShellHEAmmoHeroic">
		<Behaviors>
			<FXListBehavior id="ModuleTag_FXList" xai:joinAction="Replace">
				<DieMuxData DeathTypes="ALL"/>
				<Event FX="FX_GDICombatEngineerShellHitHEAmmoHeroic"/>
			</FXListBehavior>
		</Behaviors>
	</GameObject>
</AssetDeclaration>