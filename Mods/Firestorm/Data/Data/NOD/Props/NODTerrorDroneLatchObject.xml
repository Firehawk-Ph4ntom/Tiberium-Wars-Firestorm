<AssetDeclaration xmlns="uri:ea.com:eala:asset" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xai="uri:ea.com:eala:asset:instance">
	<!-- Normal Latch Object -->
	<GameObject id="NODTerrorDroneLatchObject" KindOf="NOT_AUTOACQUIRABLE RESIST_EMP" RadarPriority="NOT_ON_RADAR" Side="NOD" EditorName="NODTerrorDroneLatchObject" EditorSorting="SYSTEM">
		<ArmorSet Armor="NoArmor"/>
		<Draws>
			<ScriptedModelDraw id="ModuleTag_Draw">
				<ModelConditionState ParseCondStateType="PARSE_DEFAULT">
					<Model Name=""/>
				</ModelConditionState>
			</ScriptedModelDraw>
		</Draws>
		<Behaviors>
			<Physics id="ModuleTag_Physics"/>
			<AttachUpdate id="ModuleTag_AttachUpdate" Range="15.0" Teleport="true" UseGeometry="false" DetachWhenParentHealed="true">
				<ObjectFilter Rule="NONE" Relationship="ALLIES ENEMIES NEUTRAL" Include="VEHICLE">
					<!-- Terror Drone -->
					<ExcludeThing>NODTerrorDrone</ExcludeThing>
					<!-- Alien Vehicles -->
					<ExcludeThing>AlienGunWalker</ExcludeThing>
					<ExcludeThing>AlienContaminator</ExcludeThing>
					<ExcludeThing>AlienRazorback</ExcludeThing>
					<ExcludeThing>AlienRazorback_Flying</ExcludeThing>
					<ExcludeThing>AlienSeekerTank</ExcludeThing>
					<ExcludeThing>AlienHarvester</ExcludeThing>
					<ExcludeThing>AlienDevourerTank</ExcludeThing>
					<ExcludeThing>AlienCorrupter</ExcludeThing>
					<ExcludeThing>AlienStingray</ExcludeThing>
					<ExcludeThing>AlienMechapede</ExcludeThing>
					<ExcludeThing>AlienMobileWarpBeacon</ExcludeThing>
					<ExcludeThing>AlienAnnihilatorTripod</ExcludeThing>
					<ExcludeThing>AlienEradicatorHexapod</ExcludeThing>
					<ExcludeThing>AlienPlanetaryAnnihilator</ExcludeThing>
					<ExcludeThing>AlienExplorer</ExcludeThing>
					<ExcludeThing>AlienGuardianTank</ExcludeThing>
					<ExcludeThing>AlienIrradiator</ExcludeThing>
					<ExcludeThing>AlienReaver</ExcludeThing>
				</ObjectFilter>
			</AttachUpdate>
			<FireWeaponCollide id="ModuleTag_FireWeaponCollide" CollideWeapon="NODTerrorDroneLatchWeapon"/>
			<DestroyDie id="ModuleTag_Die">
				<DieMuxData DeathTypes="ALL"/>
			</DestroyDie>
		</Behaviors>
		<AI>
			<AIUpdate id="ModuleTag_AI" AutoAcquireEnemiesWhenIdle="NO"/>
		</AI>
		<Body>
			<ActiveBody id="ModuleTag_Body" MaxHealth="1000000"/>
		</Body>
	</GameObject>
	<!-- Alien Latch Object -->
	<GameObject id="NODTerrorDroneLatchObjectAlien" inheritFrom="NODTerrorDroneLatchObject" EditorName="NODTerrorDroneLatchObjectAlien">
		<Behaviors>
			<AttachUpdate id="ModuleTag_AttachUpdate" xai:joinAction="Replace" Range="15.0" Teleport="true" UseGeometry="false" DetachWhenParentHealed="true">
				<ObjectFilter Rule="NONE" Relationship="ALLIES ENEMIES NEUTRAL">
					<!-- Alien Vehicles -->
					<IncludeThing>AlienGunWalker</IncludeThing>
					<IncludeThing>AlienContaminator</IncludeThing>
					<IncludeThing>AlienRazorback</IncludeThing>
					<IncludeThing>AlienRazorback_Flying</IncludeThing>
					<IncludeThing>AlienSeekerTank</IncludeThing>
					<IncludeThing>AlienHarvester</IncludeThing>
					<IncludeThing>AlienDevourerTank</IncludeThing>
					<IncludeThing>AlienCorrupter</IncludeThing>
					<IncludeThing>AlienStingray</IncludeThing>
					<IncludeThing>AlienMechapede</IncludeThing>
					<IncludeThing>AlienMobileWarpBeacon</IncludeThing>
					<IncludeThing>AlienAnnihilatorTripod</IncludeThing>
					<IncludeThing>AlienEradicatorHexapod</IncludeThing>
					<IncludeThing>AlienPlanetaryAnnihilator</IncludeThing>
					<IncludeThing>AlienExplorer</IncludeThing>
					<IncludeThing>AlienGuardianTank</IncludeThing>
					<IncludeThing>AlienIrradiator</IncludeThing>
					<IncludeThing>AlienReaver</IncludeThing>
					<!-- Terror Drone -->
					<ExcludeThing>NODTerrorDrone</ExcludeThing>
				</ObjectFilter>
			</AttachUpdate>
		</Behaviors>
	</GameObject>
</AssetDeclaration>